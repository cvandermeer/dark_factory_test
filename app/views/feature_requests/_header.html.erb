<header>
  <h1><%= feature_request.title %></h1>
  <div class="fr-show__status">Status: <strong><%= feature_request.status %></strong></div>
  <% if feature_request.active? %>
    <%= button_to "Stop iteration", stop_feature_request_path(feature_request), method: :post,
                  data: { turbo_confirm: "Stop this iteration loop?" },
                  class: "fr-show__stop" %>
  <% end %>
  <% if feature_request.landed_commit_sha.present? %>
    <div class="fr-show__commit">Landed commit: <code><%= feature_request.landed_commit_sha %></code></div>
  <% end %>
  <% if feature_request.review_verdict.present? %>
    <div class="fr-show__review">
      <strong>Review:</strong> <%= feature_request.review_verdict.humanize %>
      <% if feature_request.review_body.present? %>
        <pre><%= feature_request.review_body %></pre>
      <% end %>
    </div>
  <% end %>
  <% if feature_request.failure_reason.present? %>
    <div class="fr-show__failure">
      <strong>Failure:</strong>
      <pre><%= feature_request.failure_reason %></pre>
    </div>
  <% end %>
  <% if feature_request.status == "failed" %>
    <%= button_to "Retry", retry_feature_request_path(feature_request), method: :post,
                  class: "fr-show__retry" %>
  <% end %>
</header>
