<%= tag.div id: dom_id(feature_request), class: "fr-card fr-card--#{feature_request.status}" do %>
  <%= link_to feature_request, class: "fr-card__link" do %>
    <div class="fr-card__title"><%= feature_request.title %></div>
    <% if feature_request.source == "automatic" %>
      <div class="fr-card__source">automatic</div>
    <% end %>
    <div class="fr-card__body"><%= truncate(feature_request.body, length: 120) %></div>

    <% case feature_request.status %>
    <% when "doing" %>
      <div class="fr-card__status">
        <span class="fr-spinner"></span> implementing...
      </div>
    <% when "reviewing" %>
      <div class="fr-card__status">
        <span class="fr-spinner fr-spinner--reviewing"></span> reviewing...
      </div>
    <% when "addressing_feedback" %>
      <div class="fr-card__status">
        <span class="fr-spinner fr-spinner--addressing"></span> addressing feedback...
      </div>
    <% when "landing" %>
      <div class="fr-card__status">
        <span class="fr-spinner fr-spinner--landing"></span> landing on main...
      </div>
    <% when "done" %>
      <div class="fr-card__status">
        <% if feature_request.landed_commit_sha.present? %>
          landed <code><%= feature_request.landed_commit_sha.first(7) %></code>
        <% else %>
          done
        <% end %>
      </div>
    <% when "stopped" %>
      <div class="fr-card__status">
        stopped
      </div>
    <% when "failed" %>
      <div class="fr-card__status fr-card__status--failed">
        <%= truncate(feature_request.failure_reason.to_s, length: 80) %>
      </div>
    <% end %>
  <% end %>

  <% if feature_request.active? %>
    <%= button_to "Stop", stop_feature_request_path(feature_request), method: :post,
                  data: { turbo_confirm: "Stop this iteration loop?" },
                  class: "fr-card__stop" %>
  <% end %>

  <% if feature_request.status == "failed" %>
    <%= button_to "Retry", retry_feature_request_path(feature_request), method: :post,
                  class: "fr-card__retry" %>
  <% end %>

  <% if %w[done stopped failed].include?(feature_request.status) %>
    <%= button_to "Delete", feature_request, method: :delete,
                  data: { turbo_confirm: "Remove this card? (Does not touch git history.)" },
                  class: "fr-card__delete" %>
  <% end %>
<% end %>
